# --- AI Providers (configure one) ---
# Google Gemini API Key
GEMINI_API_KEY=
# Anthropic API Key
ANTHROPIC_API_KEY=
# OpenAI API Key
OPENAI_API_KEY=

# --- Data Sources ---
# Productboard API Token (optional - demo mode used if not set)
PRODUCTBOARD_API_TOKEN=
# Attention API Key (optional - demo mode used if not set)
ATTENTION_API_KEY=

# --- Analytics Providers (configure one) ---
# Pendo Integration Key (optional - enables usage insights and on-demand history lookups)
PENDO_INTEGRATION_KEY=
# Amplitude API Key (format: apiKey:secretKey)
AMPLITUDE_API_KEY=
# PostHog API Key (format: apiKey:projectId)
POSTHOG_API_KEY=

# --- Ticket Providers ---
# Atlassian credentials (optional - enables Jira + Confluence read/write)
ATLASSIAN_DOMAIN=
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
# Linear API Key (optional - enables Linear ticket creation)
LINEAR_API_KEY=

# --- Auth ---
# Optional lightweight auth for public deployments
# If APP_BASIC_AUTH_PASSWORD is set, the entire app and API require HTTP Basic Auth
# IMPORTANT: If any API keys above are set, APP_BASIC_AUTH_PASSWORD must also be set
# or the app will return 503 (fail-closed security posture).
APP_BASIC_AUTH_USERNAME=viewer
APP_BASIC_AUTH_PASSWORD=
# Legacy aliases (supported but deprecated):
# BASIC_AUTH_USERNAME=
# BASIC_AUTH_PASSWORD=
